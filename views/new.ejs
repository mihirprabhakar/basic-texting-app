<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Chat</title>
</head>
<body>
    <h3>Write new chat</h3>
    <form action="/chats" method="post">
        <input type="text" placeholder="Who are you?" name="from">
        <br><br>
        <textarea name="msg" id="" cols="30" rows="10" placeholder="write your message here"></textarea>
        <br><br>
        <input type="text" placeholder="Add reciever name" name="to">
        <br><br>
        <button>Create message</button>

    </form>
    
</body>
</html>